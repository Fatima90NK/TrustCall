# GCP
PROJECT_ID=your-gcp-project-id
ENVIRONMENT=development

# Nokia as Code
NOKIA_BASE_URL=https://api.nokia.com/camara
NOKIA_CLIENT_ID=your-client-id
NOKIA_CLIENT_SECRET=your-client-secret

# RapidAPI (alternative to Nokia OAuth)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=network-as-code.nokia.rapidapi.com
RAPIDAPI_BASE_URL=https://network-as-code.p-eu.rapidapi.com

# TrustCall
TRUSTCALL_API_KEY=your-api-key-for-callers
SCORE_CACHE_TTL=300
NOKIA_REQUEST_TIMEOUT=5
